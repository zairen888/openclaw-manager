{
  "name": "openclaw-manager",
  "version": "1.0.0",
  "description": "OpenClaw 鍏ㄥ姛鑳界鐞嗗櫒 - 妗岄潰瀹㈡埛绔?,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.zairen.openclaw-manager",
    "productName": "OpenClaw Manager",
    "directories": {
      "output": "dist"
    },
    "files": [
      "app/**/*",
      "main.js",
      "package.json"
    ],
    "win": {
      "target": "portable",
      "icon": "app/icon.png"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
